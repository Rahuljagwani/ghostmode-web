# .env.local → loaded by: npm run local (localhost backend)
# .env.dev   → loaded by: npm run dev / npm run build:dev (deployed backend)
#
# npm run local      → .env.local (localhost)
# npm run dev        → .env.dev (api.renekin.com)
# npm run build:local → .env.local (localhost)
# npm run build:dev  → .env.dev (api.renekin.com)

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_APP_NAME=Ghost
